# AWS Credentials (IAM user with read-only access)
AWS_ACCESS_KEY_ID=your_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=us-east-1

# GitHub Personal Access Token (repo + read:org scope)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-org-or-username

# Prowler (optional — runs with AWS credentials above)
# No additional config needed if AWS creds are set

# Trivy (optional — runs locally, no credentials needed)
# No additional config needed
